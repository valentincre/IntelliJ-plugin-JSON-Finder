<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.valentincre.intellijpluginjsonfinder</id>
    <name>IntelliJ-plugin-JSON-Finder</name>
    <vendor>valentincre</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.json</depends>

    <resource-bundle>messages.JsonFinderBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- index → service → navigation → documentation → annotator → search → settings -->
        <fileBasedIndex implementation="com.github.valentincre.intellijpluginjsonfinder.index.JsonKeyIndex"/>
        <projectService
            serviceInterface="com.github.valentincre.intellijpluginjsonfinder.service.JsonFinderProjectService"
            serviceImplementation="com.github.valentincre.intellijpluginjsonfinder.service.JsonFinderProjectServiceImpl"/>
        <gotoDeclarationHandler implementation="com.github.valentincre.intellijpluginjsonfinder.navigation.JsonKeyGotoHandler"/>
        <lang.documentationProvider
            implementation="com.github.valentincre.intellijpluginjsonfinder.documentation.JsonKeyDocumentationProvider"
            language="any"/>
        <platform.backend.documentation.targetProvider
            implementation="com.github.valentincre.intellijpluginjsonfinder.documentation.JsonKeyDocumentationTargetProvider"/>
        <!-- annotator slot (Epic 5) -->
        <!-- language="any" does not trigger the annotator in IntelliJ 2025.2; registering for each target language explicitly -->
        <annotator language="JSON"
                   implementationClass="com.github.valentincre.intellijpluginjsonfinder.annotator.JsonKeyAnnotator"/>
        <annotator language="TypeScript"
                   implementationClass="com.github.valentincre.intellijpluginjsonfinder.annotator.JsonKeyAnnotator"/>
        <annotator language="JavaScript 1.8.5"
                   implementationClass="com.github.valentincre.intellijpluginjsonfinder.annotator.JsonKeyAnnotator"/>
        <annotator language="kotlin"
                   implementationClass="com.github.valentincre.intellijpluginjsonfinder.annotator.JsonKeyAnnotator"/>
        <annotator language="JAVA"
                   implementationClass="com.github.valentincre.intellijpluginjsonfinder.annotator.JsonKeyAnnotator"/>
        <!-- search slot (Epic 4) -->
        <searchScopesProvider implementation="com.github.valentincre.intellijpluginjsonfinder.search.JsonKeySearchScopeProvider"/>
        <findInProjectSearchEngine implementation="com.github.valentincre.intellijpluginjsonfinder.search.JsonKeyFindInProjectSearchEngine"/>
        <searchEverywhereContributor
            id="JsonKeySearchEverywhereContributor"
            implementation="com.github.valentincre.intellijpluginjsonfinder.search.JsonKeySearchEverywhereContributorFactory"/>
        <!-- settings slot (Epic 6) -->
        <projectService serviceImplementation="com.github.valentincre.intellijpluginjsonfinder.settings.JsonFinderSettings"/>
        <projectConfigurable
            id="com.github.valentincre.intellijpluginjsonfinder.settings.JsonFinderConfigurable"
            instance="com.github.valentincre.intellijpluginjsonfinder.settings.JsonFinderConfigurable"
            displayName="JSON Finder"
            groupId="tools"/>
    </extensions>
</idea-plugin>
